# Server
PORT=4000
CLIENT_ORIGIN=http://127.0.0.1:5500

# How often (ms) to check for elections whose closesAt time has passed and
# auto-close them. Optional — defaults to 30000 (30s) if not set.
ELECTION_CLOSE_CHECK_MS=30000

# MongoDB Atlas connection string (Database > Connect > Drivers in the Atlas UI).
# Replace <db_password> with your real database user's password, and add a
# database name before the "?" if it isn't there already, e.g. .../cossa_vote?retryWrites...
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster0.xxxxx.mongodb.net/cossa_vote?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=6h
ADMIN_JWT_EXPIRES_IN=4h

# Outgoing email (verification codes), sent via Brevo's HTTP API.
# Sign up free at https://brevo.com, create an API key at
# https://app.brevo.com/settings/keys/api, and set EMAIL_FROM to an email
# address you've verified as a sender in Brevo (Senders, Domains & Dedicated
# IPs > Senders > Add a sender — they'll email you a 6-digit code to confirm
# you own it). No domain purchase or DNS setup required.
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=your_verified_sender@example.com
EMAIL_FROM_NAME="COSSA Vote"

# Used once by db/seed-admin.js to create the first electoral officer account.
ADMIN_SEED_ID=COSSA-ADM-001
ADMIN_SEED_NAME=Electoral Officer
ADMIN_SEED_EMAIL=admin@cs.university.edu.ng
ADMIN_SEED_PASSWORD=change_this_password
